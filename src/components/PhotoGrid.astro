---
import type { Photo } from '../lib/types';
import { urlFor } from '../lib/sanity';

interface Props {
  photos: Photo[];
}

const { photos } = Astro.props;
---

<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:0;">
  {photos.map((photo, index) => {
    const thumbUrl = urlFor(photo.image).width(800).height(800).fit('crop').auto('format').url();
    const fullUrl = urlFor(photo.image).width(2400).auto('format').url();

    return (
      <button
        class="block overflow-hidden cursor-zoom-in animate-initial"
        style={`animation-delay: ${(index % 8) * 60}ms; aspect-ratio:1/1;`}
        data-animate
        data-lightbox-trigger
        data-photo-url={fullUrl}
        data-photo-caption={photo.caption || ''}
        data-photo-index={index}
      >
        <img
          src={thumbUrl}
          alt=""
          class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
          loading="lazy"
          decoding="async"
        />
      </button>
    );
  })}
</div>
