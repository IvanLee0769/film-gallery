---
import { sanityClient } from '../lib/sanity';
import { sidebarRollsQuery } from '../lib/queries';

interface SidebarLink {
  label: string;
  href: string;
  rollNumber?: string;
}

interface Props {
  currentPath: string;
  currentSlug?: string;
}

const { currentPath, currentSlug } = Astro.props;

const staticLinks: SidebarLink[] = [
  { label: '展覽', href: '/' },
  { label: '攝影師', href: '/photographer' },
  { label: '關於網站', href: '/about' },
];

const rolls: SidebarLink[] = await sanityClient.fetch(sidebarRollsQuery).then((r: any[]) =>
  r.map((roll: any) => ({
    label: roll.title,
    href: `/roll/${roll.slug.current}`,
    rollNumber: roll.rollNumber,
  }))
);

function isActive(href: string, currentSlug?: string): boolean {
  if (href === '/') return currentPath === '/';
  if (href.startsWith('/roll/')) {
    if (currentSlug) return href === `/roll/${currentSlug}`;
    return currentPath.startsWith('/roll/');
  }
  return currentPath === href;
}
---

<aside id="sidebar" class="relative w-64 flex-shrink-0 h-screen sticky top-0 overflow-y-auto border-r border-warm-gray/30 bg-canvas/80 backdrop-blur-sm pt-24 pb-8 px-5 transition-all duration-300 hidden lg:block">
  <!-- Collapse toggle -->
  <button
    id="sidebar-toggle"
    class="absolute top-[88px] right-2 w-6 h-6 flex items-center justify-center rounded-full bg-warm-gray/30 hover:bg-warm-gray/50 text-canvas-dark/40 hover:text-canvas-dark transition-colors text-xs"
    aria-label="隱藏導航欄"
    title="隱藏導航欄"
  >
    ‹
  </button>

  <!-- Static links -->
  <nav class="mb-8">
    <ul class="space-y-1">
      {staticLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class={`block px-3 py-2 rounded-card text-sm transition-colors whitespace-nowrap overflow-hidden ${
              isActive(link.href)
                ? 'bg-warm-gray/50 text-brass font-medium'
                : 'text-canvas-dark/80 hover:text-brass hover:bg-warm-gray/20'
            }`}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <!-- Divider -->
  <div class="border-t border-warm-gray/30 mb-6"></div>

  <!-- Rolls list -->
  <div>
    <p class="text-xs uppercase tracking-widest text-canvas-dark/40 mb-3 px-3 whitespace-nowrap">膠卷</p>
    <ul class="space-y-0.5">
      {rolls.map((roll) => (
        <li>
          <a
            href={roll.href}
            class={`block px-3 py-1.5 rounded-card text-sm transition-colors truncate ${
              isActive(roll.href, currentSlug)
                ? 'bg-warm-gray/50 text-brass font-medium'
                : 'text-canvas-dark/70 hover:text-brass hover:bg-warm-gray/20'
            }`}
            title={roll.label}
          >
            <span class="text-xs text-canvas-dark/40 mr-1.5">{roll.rollNumber}</span>
            {roll.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</aside>

<!-- Expand button (visible when sidebar is collapsed) -->
<button
  id="sidebar-expand"
  class="fixed top-24 left-4 z-40 w-9 h-9 items-center justify-center rounded-full bg-canvas shadow-md border border-warm-gray/40 text-canvas-dark/60 hover:text-brass hover:scale-110 transition-all"
  style="display:none"
  aria-label="顯示導航欄"
  title="顯示導航欄"
>
  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
</button>

<script>
  const sidebar = document.getElementById('sidebar')!;
  const toggleBtn = document.getElementById('sidebar-toggle')!;
  const expandBtn = document.getElementById('sidebar-expand')!;
  toggleBtn.addEventListener('click', () => {
    sidebar.classList.add('-translate-x-full', '!w-0', '!px-0', '!border-r-0');
    sidebar.classList.remove('w-64');
    toggleBtn.style.display = 'none';
    expandBtn.style.display = 'flex';
  });

  expandBtn.addEventListener('click', () => {
    sidebar.classList.remove('-translate-x-full', '!w-0', '!px-0', '!border-r-0');
    sidebar.classList.add('w-64');
    toggleBtn.style.display = 'flex';
    expandBtn.style.display = 'none';
  });
</script>
