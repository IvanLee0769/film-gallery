---
import { urlFor } from '../lib/sanity';
import type { RollSummary } from '../lib/types';

interface Props {
  roll: RollSummary;
  index: number;
}

const { roll, index } = Astro.props;
const coverUrl = urlFor(roll.coverImage).width(800).height(530).auto('format').url();
const thumbPhotos = roll.photos || [];
---

<article
  class="grid grid-cols-1 md:grid-cols-5 gap-6 md:gap-10 py-12 md:py-16 border-b border-warm-gray/50 animate-initial"
  data-animate
>
  <!-- Cover Image (left) -->
  <a
    href={`/roll/${roll.slug.current}`}
    class="md:col-span-2 group block rounded-card overflow-hidden bg-white shadow-sm transition-all duration-300 ease-out hover:shadow-lg"
  >
    <div class="aspect-[3/2] overflow-hidden">
      <img
        src={coverUrl}
        alt={roll.title}
        class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
        loading={index < 2 ? 'eager' : 'lazy'}
        decoding="async"
      />
    </div>
  </a>

  <!-- Info + Thumbnails (right) -->
  <div class="md:col-span-3 flex flex-col justify-center">
    <!-- Metadata -->
    <a href={`/roll/${roll.slug.current}`} class="group">
      <span class="text-xs text-brass uppercase tracking-wider font-medium">{roll.rollNumber}</span>
      <h2 class="text-2xl md:text-3xl font-heading font-semibold mt-1 mb-2 group-hover:text-brass transition-colors">
        {roll.title}
      </h2>
      <div class="flex flex-wrap gap-x-3 gap-y-1 text-sm text-canvas-dark/50 mb-6">
        {roll.filmType && <span>{roll.filmType}</span>}
        {roll.camera && <span>· {roll.camera}</span>}
        {roll.shotDate && <span>· {new Date(roll.shotDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}</span>}
      </div>
    </a>

    <!-- Photo Thumbnails - flat row -->
    {thumbPhotos.length > 0 && (
      <div class="flex gap-2 flex-wrap">
        {thumbPhotos.slice(0, 6).map((photo) => {
          const thumbUrl = urlFor(photo.image).width(160).height(107).auto('format').url();
          return (
            <a
              href={`/roll/${roll.slug.current}`}
              class="flex-shrink-0 w-[100px] h-[67px] rounded overflow-hidden bg-warm-gray/30"
            >
              <img
                src={thumbUrl}
                alt=""
                class="w-full h-full object-cover hover:opacity-80 transition-opacity"
                loading="lazy"
                decoding="async"
              />
            </a>
          );
        })}
        {thumbPhotos.length > 6 && (
          <a
            href={`/roll/${roll.slug.current}`}
            class="flex-shrink-0 w-[100px] h-[67px] rounded bg-warm-gray/30 flex items-center justify-center text-xs text-canvas-dark/40 hover:bg-warm-gray/50 transition-colors"
          >
            +{thumbPhotos.length - 6} more
          </a>
        )}
      </div>
    )}

    {thumbPhotos.length === 0 && (
      <a
        href={`/roll/${roll.slug.current}`}
        class="inline-block text-brass text-sm hover:underline mt-2"
      >
        View this roll →
      </a>
    )}
  </div>
</article>

