---
import { urlFor } from '../lib/sanity';
import type { RollSummary } from '../lib/types';

interface Props {
  roll: RollSummary;
  index: number;
}

const { roll, index } = Astro.props;
const coverUrl = urlFor(roll.coverImage).width(600).height(400).auto('format').url();
---

<a
  href={`/roll/${roll.slug.current}`}
  class="group block rounded-card overflow-hidden bg-white shadow-sm transition-all duration-300 ease-out hover:shadow-lg hover:-translate-y-1 animate-initial"
  style={`animation-delay: ${index * 80}ms`}
  data-animate
>
  <div class="aspect-[3/2] overflow-hidden">
    <img
      src={coverUrl}
      alt={roll.title}
      class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
      loading={index < 6 ? 'eager' : 'lazy'}
      decoding="async"
    />
  </div>
  <div class="p-4">
    <span class="text-xs text-brass uppercase tracking-wider font-medium">{roll.rollNumber}</span>
    <h2 class="text-lg font-heading mt-1 group-hover:text-brass transition-colors">
      {roll.title}
    </h2>
    <div class="flex flex-wrap gap-x-3 gap-y-1 mt-2 text-sm text-canvas-dark/50">
      {roll.filmType && <span>{roll.filmType}</span>}
      {roll.camera && <span>· {roll.camera}</span>}
    </div>
  </div>
</a>
