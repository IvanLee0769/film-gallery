---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PhotoGrid from '../../components/PhotoGrid.astro';
import Lightbox from '../../components/Lightbox.tsx';
import { PortableText } from 'astro-portabletext';
import { sanityClient } from '../../lib/sanity';
import { rollBySlugQuery, allRollSlugsQuery } from '../../lib/queries';
import type { Roll } from '../../lib/types';
import { urlFor } from '../../lib/sanity';

export async function getStaticPaths() {
  const slugs: string[] = await sanityClient.fetch(allRollSlugsQuery);
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const roll: Roll | null = await sanityClient.fetch(rollBySlugQuery, { slug });

if (!roll) {
  return Astro.redirect('/404');
}

const metaItems = [
  { label: '膠卷', value: roll.filmType },
  { label: '相機', value: roll.camera },
  { label: '鏡頭', value: roll.lens },
  { label: 'ISO', value: roll.iso },
  { label: '拍攝日期', value: roll.shotDate ? new Date(roll.shotDate).toLocaleDateString('zh-TW', { year: 'numeric', month: 'long', day: 'numeric' }) : undefined },
  { label: '沖掃', value: roll.developer },
  { label: '掃描器', value: roll.scanner },
].filter((item) => item.value);
---

<BaseLayout title={roll.title} description={`${roll.rollNumber}: ${roll.title} — ${roll.filmType || ''}`} currentSlug={slug} noSidebar={true}>
  <article class="max-w-7xl mx-auto px-4 py-12 md:py-20">
    <!-- Back button -->
    <a
      href="/"
      class="inline-flex items-center gap-2 text-sm text-canvas-dark/50 hover:text-brass transition-colors mb-8 group"
    >
      <svg class="w-4 h-4 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path d="M19 12H5M12 19l-7-7 7-7"/>
      </svg>
      返回展覽
    </a>

    <!-- Title -->
    <div class="mb-8">
      <span class="text-brass text-sm uppercase tracking-wider font-medium">{roll.rollNumber}</span>
      <h1 class="text-3xl md:text-4xl font-heading font-semibold mt-2">
        {roll.title}
      </h1>
    </div>

    <!-- Photo Gallery Wall -->
    <section>
      {roll.photos && roll.photos.length > 0 ? (
        <>
          <PhotoGrid photos={roll.photos} />
          <Lightbox
            photos={roll.photos.map((p) => ({
              _key: p._key,
              url: urlFor(p.image).width(2400).auto('format').url(),
              caption: p.caption || '',
            }))}
            rollId={roll._id}
            client:load
          />
        </>
      ) : (
        <p class="text-canvas-dark/40 italic py-12 text-center">此膠卷尚無照片。</p>
      )}
    </section>

    <!-- Horizontal metadata card -->
    {metaItems.length > 0 && (
      <div class="mt-12 bg-white rounded-card p-5 shadow-sm border border-warm-gray/30">
        <div class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm">
          {metaItems.map((item) => (
            <span class="flex items-center gap-1.5">
              <span class="text-xs tracking-wider text-canvas-dark/35">{item.label}</span>
              <span class="text-canvas-dark">{item.value}</span>
            </span>
          ))}
          {roll.rating != null && roll.rating > 0 && (
            <span class="text-brass">
              {'★'.repeat(roll.rating)}{'☆'.repeat(5 - roll.rating)}
            </span>
          )}
        </div>
      </div>
    )}

    {roll.photos && roll.photos.length > 0 && (
      <p class="text-sm text-canvas-dark/30 mt-4">共 {roll.photos.length} 張照片</p>
    )}

    <!-- Notes -->
    {roll.notes && roll.notes.length > 0 && (
      <div class="prose prose-lg max-w-none font-light leading-relaxed text-canvas-dark/80 mt-12 border-t border-warm-gray/40 pt-10">
        <PortableText value={roll.notes} />
      </div>
    )}

  </article>
</BaseLayout>
